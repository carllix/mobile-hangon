<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HangOn" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash screen theme using androidx.core:core-splashscreen -->
    <style name="Theme.HangOn.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#004EE0</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.HangOn</item>
    </style>

    <!-- Transparent theme for overlay activity -->
    <style name="Theme.Transparent" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
    </style>

</resources>